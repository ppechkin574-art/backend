services:
  app:
    build: .
    command: uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload
    volumes:
      - ./src:/app/src
      - ./uploads:/app/uploads
      - ./secrets/apple_private_key.p8:/app/secrets/apple_private_key.p8
      - ./secrets/firebase_credentials.json:/app/secrets/firebase_credentials.json
    env_file:
      - .env
    ports:
      - "8000:8000"
